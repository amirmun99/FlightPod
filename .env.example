# FlightPaper environment variables (Pi side)
# Copy to /etc/flightpaper/secrets.env on the device, or to .env locally.
#
# All values are optional. If credentials are absent, the Pi runs OpenSky in
# anonymous mode.

# --- OpenSky Network credentials (optional) ----------------------------------
# Sign up at https://opensky-network.org/ and create an API client.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Pi runtime ---------------------------------------------------------------
# Path to the config file the service should load.
FLIGHTPAPER_CONFIG=/etc/flightpaper/config.yml

# --- Pi dev overrides ---------------------------------------------------------
# When set, the Pi treats this host as the dev machine (no SPI, no GPIO, no
# privileged paths). Auto-detected on macOS; set explicitly to force.
# FLIGHTPAPER_DEV=1
